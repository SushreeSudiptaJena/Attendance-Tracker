# Normalize line endings: LF in the repo for everything text.
* text=auto eol=lf

# Windows-only scripts keep CRLF.
*.bat text eol=crlf

# The Gradle wrapper script MUST stay LF or it fails on Linux/CI.
gradlew text eol=lf

# Binary assets — never touch line endings.
*.jar  binary
*.png  binary
*.webp binary
*.jpg  binary
*.keystore binary
*.jks binary
